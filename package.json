{
  "name": "stock-research",
  "version": "1.0.0",
  "description": "Stock research app with poker game",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "chart.js": "^4.5.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "roots": ["poker/tests"],
    "testMatch": ["**/*.test.js"],
    "collectCoverageFrom": [
      "poker/**/*.js",
      "!poker/tests/**",
      "!**/node_modules/**"
    ]
  }
}
