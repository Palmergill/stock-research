{
  "name": "stock-research",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "startCommand": "sh -c 'uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000}'",
  "env": {
    "DATABASE_URL": "sqlite:///./stock_data.db",
    "USE_REAL_DATA": "false"
  },
  "healthcheck": {
    "path": "/health",
    "port": 8000
  }
}
